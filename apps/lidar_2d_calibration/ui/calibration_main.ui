    <!-- Left: Scan Canvas (placeholder) -->
    <item>
     <widget class="QWidget" name="canvasPlaceholder" native="true">
      <property name="sizePolicy">
       <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
