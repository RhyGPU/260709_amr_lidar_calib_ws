            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <!-- Jog Control: Front LiDAR -->
        <item>
         <widget class="QGroupBox" name="groupJogFront">
          <property name="title">
           <string>Jog: Front LiDAR (merged→front)</string>
          </property>
          <layout class="QFormLayout" name="jogFrontLayout">
           <item row="0" column="0">
            <widget class="QLabel"><property name="text"><string>X (m):</string></property></widget>
           </item>
           <item row="0" column="1">
            <widget class="QDoubleSpinBox" name="spinJogFrontX">
             <property name="decimals"><number>4</number></property>
             <property name="minimum"><double>-10.0</double></property>
             <property name="maximum"><double>10.0</double></property>
             <property name="singleStep"><double>0.01</double></property>
             <property name="value"><double>0.0</double></property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel"><property name="text"><string>Y (m):</string></property></widget>
           </item>
           <item row="1" column="1">
            <widget class="QDoubleSpinBox" name="spinJogFrontY">
             <property name="decimals"><number>4</number></property>
             <property name="minimum"><double>-10.0</double></property>
             <property name="maximum"><double>10.0</double></property>
             <property name="singleStep"><double>0.01</double></property>
             <property name="value"><double>0.0</double></property>
            </widget>
           </item>
           <item row="2" column="0">
            <widget class="QLabel"><property name="text"><string>Yaw (°):</string></property></widget>
           </item>
           <item row="2" column="1">
            <widget class="QDoubleSpinBox" name="spinJogFrontYaw">
             <property name="decimals"><number>2</number></property>
             <property name="minimum"><double>-180.0</double></property>
             <property name="maximum"><double>180.0</double></property>
             <property name="singleStep"><double>0.5</double></property>
             <property name="value"><double>0.0</double></property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <!-- Jog Control: Rear LiDAR -->
        <item>
         <widget class="QGroupBox" name="groupJogRear">
          <property name="title">
