            </widget>
           </item>
           <item row="0" column="1">
            <layout class="QHBoxLayout" name="frontEndpointLayout">
             <item>
              <widget class="QLineEdit" name="editFrontEndpoint">
               <property name="text">
                <string>192.168.192.100:6060</string>
               </property>
               <property name="maximumWidth">
                <number>150</number>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="btnDiscoverFront">
               <property name="text">
                <string>Find</string>
               </property>
               <property name="maximumWidth">
                <number>70</number>
               </property>
               <property name="toolTip">
                <string>Front 포트를 스캔해 송신 IP를 자동으로 찾습니다</string>
               </property>
              </widget>
