        <!-- ICP Parameters -->
        <item>
         <widget class="QGroupBox" name="groupICP">
          <property name="title">
           <string>ICP Parameters</string>
          </property>
          <layout class="QFormLayout" name="icpFormLayout">
           <item row="0" column="0">
            <widget class="QLabel" name="lblMaxIter">
             <property name="text"><string>Max Iterations:</string></property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QSpinBox" name="spinMaxIter">
             <property name="minimum"><number>1</number></property>
             <property name="maximum"><number>500</number></property>
             <property name="value"><number>50</number></property>
