        <height>16777215</height>
       </size>
      </property>
      <property name="widgetResizable">
       <bool>true</bool>
      </property>
      <widget class="QWidget" name="controlPanel">
       <layout class="QVBoxLayout" name="controlLayout">
        <property name="spacing">
         <number>6</number>
        </property>
        <!-- Network (UDP) Settings -->
        <item>
         <widget class="QGroupBox" name="groupTopics">
          <property name="title">
           <string>Network (UDP)</string>
          </property>
          <layout class="QFormLayout" name="topicFormLayout">
           <item row="0" column="0">
            <widget class="QLabel" name="lblFrontTopic">
